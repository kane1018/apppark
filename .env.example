# ===== AppPark 環境変数のサンプル =====
# このファイルを .env.local にコピーして値を設定してください。
# （.env.local は .gitignore 済みで、公開されません）

# 公開サイトのURL（末尾スラッシュなし）。
# canonical / OGP / sitemap / 構造化データの絶対URLに使われます。
# 例：https://apppark.example.com
NEXT_PUBLIC_SITE_URL=https://apppark.vercel.app

# Google Search Console の「HTMLタグ」確認用トークン。
# GSCで「URLプレフィックス」→「HTMLタグ」を選ぶと
#   <meta name="google-site-verification" content="xxxxxxxx" />
# が表示されます。その content の値（xxxxxxxx の部分）だけをここに設定してください。
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ===== ログイン認証（Supabase Auth） =====
# 以下2つを設定すると、Google / マジックリンク / メール＋パスワードの本格ログインが有効になります。
# 未設定のあいだは、メール＋公開表示名の簡易ログイン（この端末に保存）で動作します。
#
# 手順：
#  1) https://supabase.com でプロジェクトを作成
#  2) Project Settings → API から URL と anon public key を取得して下記に設定
#  3) Authentication → Providers で Google を有効化（Google CloudのOAuthクライアントを設定）
#  4) Authentication → URL Configuration の Redirect URLs に
#       https://<本番URL>/auth/callback
#     （ローカル確認時は http://localhost:3000/auth/callback も）を追加
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# ⚠️ service_role key は絶対にここ（NEXT_PUBLIC_）やクライアントに置かないでください。
#    anon key はRLSで保護される前提の公開鍵です。RLSは必ず有効化してください
#    （supabase/migrations/0002_rls_policies.sql）。詳細は docs/security/AUTH_SETUP.md。
